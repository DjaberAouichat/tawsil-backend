MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=tawsil_db
JWT_SECRET=
JWT_EXPIRES_IN=7d
NODE_ENV=development
CORS_ALLOWED_ORIGINS=*
