# ─────────────────────────────────────────────────────────
# Tawsil Backend — Environment Variables
# ─────────────────────────────────────────────────────────

# Database
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=tawsil_db

# JWT
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# App
NODE_ENV=production
PORT=3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Geoapify (maps & routing)
GEOAPIFY_API_KEY=

# MySQL pool (5 for Basic tier, 10 for General Purpose)
MYSQL_POOL_LIMIT=5
JSON_BODY_LIMIT=1mb

# SMTP (Brevo)
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# Default bootstrap credentials (change after first login)
DEFAULT_ADMIN_PASSWORD=
DEFAULT_AUTHORITY_PASSWORD=

# ── Azure-specific (optional) ──
# Set these if using Azure Database for MySQL instead of local MySQL
# AZURE_MYSQL_HOST=
# AZURE_MYSQL_USER=
# AZURE_MYSQL_PASSWORD=
# AZURE_MYSQL_DATABASE=
# MYSQLCONNSTR_AZURE_MYSQL_CONNECTIONSTRING=
